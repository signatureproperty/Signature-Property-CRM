
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to read/write to their own avatar folder
    match /avatars/{agencyId}/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow authenticated users to upload their upgrade receipts
    match /upgrade_receipts/{agencyId}/{fileName} {
      allow write: if request.auth != null;
      allow read: if request.auth != null;
    }
    
    // Allow any authenticated user to read/write to the documents folder.
    match /documents/{agencyId}/{propertyId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Allow system config and branding access for administrators
    match /system/{allPaths=**} {
      allow read: if true; // Publicly readable for manifest/PWA
      allow write: if request.auth != null; // Protected write
    }
  }
}
