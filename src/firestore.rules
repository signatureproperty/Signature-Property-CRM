rules_version = '2';

function isAgencyMember(agencyId) {
    return exists(/databases/$(database)/documents/agencies/$(agencyId)/teamMembers/$(request.auth.uid));
}

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Generic fallback for development
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    match /agencies/{agencyId} {
       allow read: if request.auth.uid == agencyId || isAgencyMember(agencyId);
       allow write: if request.auth.uid == agencyId;
    }
    
    match /agencies/{agencyId}/{subcollection}/{documentId} {
      allow read, write: if isAgencyMember(agencyId) || request.auth.uid == agencyId;
    }
    
    match /agencies/{agencyId}/inboxMessages/{messageId} {
      allow read, update, delete: if request.auth.uid == agencyId;
      allow create: if isAgencyMember(agencyId);
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    match /agents/{agentId} {
       allow read, write: if request.auth.uid == agentId;
    }

    match /invitations/{inviteId} {
      // Allow creation by any authenticated user (Agency Admin)
      allow create: if request.auth != null;
      // Allow READ/UPDATE/DELETE if the 'toEmail' field matches the logged-in user's email
      allow read, update, delete: if request.auth != null && (resource.data.toEmail == request.auth.token.email || request.auth.uid == resource.data.fromAgencyId);
    }

    match /upgradeRequests/{requestId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
