rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Avatars - user can only write their own, any authenticated user can read
    match /avatars/{agencyId}/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Upgrade receipts (payment screenshots) - any authenticated user
    match /upgrade_receipts/{agencyId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Property documents - any authenticated user (agency isolation via path)
    match /documents/{agencyId}/{propertyId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
